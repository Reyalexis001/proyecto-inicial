# ══════════════════════════════════════════════════════════
# Sistema de Actas Mexicanas — Variables de Entorno
# Copia este archivo como ".env" y rellena los valores reales.
# NUNCA subas el .env a GitHub.
# ══════════════════════════════════════════════════════════

# ── Servidor ──────────────────────────────────────────────
# Render asigna PORT automáticamente; no lo cambies en producción.
PORT=3000

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://dzhwhcefqqmwowluztq.supabase.co
SUPABASE_SERVICE_ROLE=TU_SERVICE_ROLE_KEY_AQUI

# ── MercadoPago ───────────────────────────────────────────
MP_ACCESS_TOKEN=TU_ACCESS_TOKEN_DE_MP_AQUI
# "true" para usar sandbox (checkout de pruebas), "false" para producción
MP_SANDBOX=true

# ── URLs del despliegue ───────────────────────────────────
# Después de crear el servicio en Render, pon aquí la URL que te asigna.
# Ejemplo: https://actas-mexicanas.onrender.com
BACKEND_URL=https://TU-APP.onrender.com
FRONTEND_URL=https://TU-APP.onrender.com

# ── JWT (sesiones de admin) ───────────────────────────────
# Genera una cadena aleatoria larga. Puedes usar:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CAMBIA_POR_UNA_CADENA_ALEATORIA_LARGA

# ── Credenciales del administrador ───────────────────────
# Estas son las credenciales con las que el admin entra al panel.
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=CAMBIA_POR_PASSWORD_SEGURO
